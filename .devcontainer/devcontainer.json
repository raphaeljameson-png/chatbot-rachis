{
  "name": "chatbot-rachis dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "npm install -g firebase-tools && cd functions && npm install && cd ../scripts && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "toba.vsfire"
      ]
    }
  },
  "forwardPorts": [5000, 5001, 8080, 9000, 9099, 4000, 4400, 4500],
  "portsAttributes": {
    "5001": { "label": "Functions emulator" },
    "8080": { "label": "Firestore emulator" },
    "4000": { "label": "Emulator UI" }
  },
  "remoteUser": "node"
}
